+
+/* ============================================================
+   Products mega menu (added)
+   ============================================================ */
+.megaWrap {
+  position: relative;
+}
+
+.megaTrigger {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  background: transparent;
+  border: none;
+  cursor: pointer;
+  font: inherit;
+}
+
+.megaChevron {
+  transition: transform var(--transition-fast);
+  opacity: 0.8;
+}
+.megaChevronOpen {
+  transform: rotate(180deg);
+  opacity: 1;
+}
+
+.megaPanel {
+  position: absolute;
+  top: calc(100% + 12px);
+  left: 50%;
+  transform: translateX(-50%);
+  width: min(880px, calc(100vw - 32px));
+  background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(7, 12, 24, 0.98));
+  border: 1px solid rgba(255, 255, 255, 0.08);
+  border-radius: var(--radius-xl, 16px);
+  box-shadow:
+    0 20px 60px -10px rgba(0, 0, 0, 0.6),
+    0 0 0 1px rgba(255, 255, 255, 0.03) inset;
+  backdrop-filter: blur(18px);
+  -webkit-backdrop-filter: blur(18px);
+  padding: 0;
+  z-index: 110;
+  animation: megaFade 180ms ease-out;
+}
+
+@keyframes megaFade {
+  from { opacity: 0; transform: translate(-50%, -6px); }
+  to   { opacity: 1; transform: translate(-50%, 0); }
+}
+
+.megaInner {
+  padding: var(--space-5, 20px);
+}
+
+.megaHeader {
+  display: flex;
+  align-items: flex-end;
+  justify-content: space-between;
+  gap: var(--space-4, 16px);
+  margin-bottom: var(--space-4, 16px);
+  padding: 0 var(--space-2, 8px);
+}
+
+.megaEyebrow {
+  font-size: 0.7rem;
+  font-weight: 600;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: var(--color-accent-400);
+  margin-bottom: 4px;
+}
+
+.megaTitle {
+  font-size: 1.05rem;
+  font-weight: 600;
+  color: var(--color-neutral-0, #fff);
+  margin: 0;
+}
+
+.megaAllLink {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  font-size: 0.8rem;
+  font-weight: 500;
+  color: var(--color-neutral-300, #cbd5e1);
+  padding: 6px 10px;
+  border-radius: var(--radius-md, 8px);
+  transition: color var(--transition-fast), background var(--transition-fast);
+}
+.megaAllLink:hover {
+  color: var(--color-neutral-0, #fff);
+  background: rgba(255, 255, 255, 0.06);
+}
+
+.megaGrid {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: var(--space-3, 12px);
+}
+
+.megaCard {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  border-radius: var(--radius-lg, 12px);
+  overflow: hidden;
+  background: rgba(255, 255, 255, 0.02);
+  border: 1px solid rgba(255, 255, 255, 0.06);
+  transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
+  text-decoration: none;
+  color: inherit;
+}
+
+.megaCard:hover {
+  transform: translateY(-2px);
+  border-color: rgba(96, 165, 250, 0.45);
+  background: rgba(59, 130, 246, 0.06);
+}
+
+.megaImageWrap {
+  position: relative;
+  aspect-ratio: 16 / 10;
+  overflow: hidden;
+}
+
+.megaImageWrap img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  transition: transform 500ms ease;
+}
+
+.megaCard:hover .megaImageWrap img {
+  transform: scale(1.06);
+}
+
+.megaImageOverlay {
+  position: absolute;
+  inset: 0;
+  background: linear-gradient(180deg, rgba(7, 12, 24, 0) 40%, rgba(7, 12, 24, 0.85) 100%);
+}
+
+.megaIconBadge {
+  position: absolute;
+  top: 10px;
+  left: 10px;
+  width: 30px;
+  height: 30px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: 8px;
+  background: rgba(15, 23, 42, 0.7);
+  backdrop-filter: blur(8px);
+  -webkit-backdrop-filter: blur(8px);
+  color: var(--color-accent-300, #93c5fd);
+  border: 1px solid rgba(255, 255, 255, 0.08);
+}
+
+.megaCardBody {
+  padding: var(--space-3, 12px) var(--space-3, 12px) var(--space-4, 16px);
+}
+
+.megaCardTitleRow {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  margin-bottom: 4px;
+}
+
+.megaCardTitle {
+  font-size: 0.95rem;
+  font-weight: 600;
+  color: var(--color-neutral-0, #fff);
+  letter-spacing: 0.01em;
+}
+
+.megaCardArrow {
+  color: var(--color-neutral-400, #94a3b8);
+  transform: translateX(-4px);
+  opacity: 0;
+  transition: transform 220ms ease, opacity 220ms ease, color 220ms ease;
+}
+.megaCard:hover .megaCardArrow {
+  transform: translateX(0);
+  opacity: 1;
+  color: var(--color-accent-400, #60a5fa);
+}
+
+.megaCardDesc {
+  font-size: 0.8rem;
+  line-height: 1.45;
+  color: var(--color-neutral-400, #94a3b8);
+  margin: 0;
+}
+
+/* Mobile submenu */
+.mobileProductsTrigger {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  width: 100%;
+  background: transparent;
+  border: none;
+  cursor: pointer;
+  font: inherit;
+  text-align: left;
+}
+
+.mobileSubmenu {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  padding: 4px 0 8px var(--space-3, 12px);
+  border-left: 1px solid rgba(255, 255, 255, 0.08);
+  margin-left: var(--space-2, 8px);
+}
+
+.mobileSubLink {
+  display: flex;
+  align-items: flex-start;
+  gap: 10px;
+  padding: 10px 12px;
+  border-radius: var(--radius-md, 8px);
+  text-decoration: none;
+  transition: background var(--transition-fast);
+}
+.mobileSubLink:hover {
+  background: rgba(255, 255, 255, 0.04);
+}
+
+.mobileSubIcon {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 28px;
+  height: 28px;
+  flex-shrink: 0;
+  border-radius: 8px;
+  background: rgba(59, 130, 246, 0.12);
+  color: var(--color-accent-300, #93c5fd);
+  margin-top: 2px;
+}
+
+.mobileSubLabel {
+  display: block;
+  font-size: 0.9rem;
+  font-weight: 600;
+  color: var(--color-neutral-0, #fff);
+}
+
+.mobileSubDesc {
+  display: block;
+  font-size: 0.75rem;
+  line-height: 1.4;
+  color: var(--color-neutral-400, #94a3b8);
+  margin-top: 2px;
+}
+
+/* Responsive */
+@media (max-width: 960px) {
+  .megaPanel { width: min(720px, calc(100vw - 24px)); }
+  .megaGrid { grid-template-columns: repeat(3, 1fr); }
+}
+
+@media (max-width: 768px) {
+  .megaWrap { display: none; }
+}
